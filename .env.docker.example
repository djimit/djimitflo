# =============================================================================
# Djimitflo Docker Environment Configuration
# =============================================================================
# Copy this file to .env.docker and adjust values before running:
#   cp .env.docker.example .env.docker
#   docker compose up -d
# =============================================================================

# Server
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# CORS — comma-separated list of allowed origins
# In Docker, set this to your actual domain or IP
CORS_ORIGINS=http://localhost:3001

# Database — path to SQLite database file
# In Docker, use the persistent volume path
DB_PATH=/data/djimitflo.sqlite

# Dashboard — path to built dashboard static files
# In Docker, this is set automatically in the Dockerfile
DASHBOARD_PATH=/app/packages/dashboard/dist

# Backup — directory for backup artifacts
# In Docker, use a subdirectory of the persistent volume
BACKUP_DIR=/data/backups

# Docker host port (change if port 3001 is already in use)
DJIMITFLO_HOST_PORT=3001

# =============================================================================
# Authentication — REQUIRED in production
# =============================================================================
# JWT secret — MUST be changed for production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-characters

# JWT token expiration
JWT_EXPIRES_IN=24h

# Bootstrap admin user — created on first startup only
# Both email and password must be provided
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password

# Bootstrap admin role (default: admin)
# AUTH_BOOTSTRAP_ADMIN_ROLE=admin

# =============================================================================
# OpenCode Executor — Optional
# =============================================================================
# Path to the OpenCode CLI binary
# NOTE: OpenCode is NOT installed in the Docker image by default.
# To enable OpenCode execution, either:
#   1. Mount the binary: docker run -v /path/to/opencode:/usr/local/bin/opencode ...
#   2. Install it in a custom image derived from this one
# OPENCODE_BIN_PATH=/usr/local/bin/opencode

# Execution timeout in milliseconds (default: 600000 = 10 minutes)
# OPENCODE_EXECUTION_TIMEOUT_MS=600000

# Skip permission prompts for automation (default: false)
# WARNING: Setting this to true bypasses OpenCode's permission model.
# OPENCODE_SKIP_PERMISSIONS=false

# Output format (default: json)
# OPENCODE_OUTPUT_FORMAT=json

# Hostname — auto-detected in Docker, but can be overridden for backup manifest
# HOSTNAME=djimitflo-server