{
  "name": "@djimitflo/server",
  "version": "0.5.8",
  "private": true,
  "description": "Djimitflo backend server (Express + TypeScript + SQLite)",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "db:migrate": "tsx src/database/migrate.ts",
    "db:seed": "tsx src/database/seed.ts",
    "github:cocreate": "tsx src/scripts/github-cocreate.ts",
    "swarm:proof": "tsx src/scripts/swarm-proof-run.ts",
    "demo:proof": "tsx src/scripts/swarm-demo-proof.ts"
  },
  "dependencies": {
    "@djimitflo/telegram": "*",
    "@djimitflo/shared": "*",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "tar-stream": "^2.2.0",
    "ws": "^8.20.1",
    "zod": "^3.23.8",
    "@djimitflo/agent-catalog": "*"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/tar-stream": "^2.2.3",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
