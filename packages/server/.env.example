# Djimitflo Server Configuration
# Copy this file to .env and adjust values as needed.

# Server
PORT=3001
HOST=localhost

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# Database — path to SQLite database file
# Defaults to <project-root>/.data/djimitflo.sqlite
# DB_PATH=./.data/djimitflo.sqlite

# Environment — enables verbose error traces when set to "development"
# NODE_ENV=development

# Authentication — JWT secret (REQUIRED in production)
# In development, a default secret is used with a warning.
# In production, the server will refuse to start without this.
# JWT_SECRET=your-strong-random-secret-at-least-32-characters

# Authentication — JWT token expiration
# Defaults to 24h
# JWT_EXPIRES_IN=24h

# Authentication — Bootstrap admin user
# Only creates a user if no users exist in the database.
# Both email and password must be provided for bootstrap to occur.
# AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# AUTH_BOOTSTRAP_ADMIN_PASSWORD=<set-a-strong-password>

# Authentication — Bootstrap admin role (default: admin)
# AUTH_BOOTSTRAP_ADMIN_ROLE=admin

# OpenCode Executor — path to the OpenCode CLI binary
# Defaults to /Users/dlandman/.opencode/bin/opencode if not set
# OPENCODE_BIN_PATH=/usr/local/bin/opencode

# OpenCode Executor — execution timeout in milliseconds
# Defaults to 600000 (10 minutes)
# OPENCODE_EXECUTION_TIMEOUT_MS=600000

# OpenCode Executor — skip permission prompts for automation (default: false)
# WARNING: Setting this to true bypasses OpenCode's permission model.
# Only enable when Djimitflo's policy engine has pre-approved the task.
# OPENCODE_SKIP_PERMISSIONS=false

# OpenCode Executor — output format (default: json)
# Changing from 'json' to 'default' disables structured event parsing
# and falls back to heuristic line-by-line parsing.
# OPENCODE_OUTPUT_FORMAT=json

# Loop runtime binaries (L4) — claude / gemini / editor(=cline) maker runtimes.
# The loop path spawns these headless; defaults resolve to the bare CLI name on
# PATH. Override to pin an absolute path. The `editor` runtime maps to the cline
# CLI (an autonomous AI editor-agent); aider/cursor are not wired up.
# CLAUDE_BIN_PATH=claude
# GEMINI_BIN_PATH=gemini
# CLINE_BIN_PATH=cline
#
# Per-runtime model overrides (optional). Injected as --model / -m at spawn time.
# DJIMITFLO_CLAUDE_MODEL=
# DJIMITFLO_GEMINI_MODEL=
# DJIMITFLO_CLINE_MODEL=
#
# cline thinking effort (optional, default: medium).
# DJIMITFLO_CLINE_THINKING=medium

# Loop runtime security (P1 / G15) — controls for spawned codex/opencode workers.
#
# RUNTIME_ALLOW_SKIP_PERMISSIONS — master gate for approval/sandbox bypass.
# A maker/checker may REQUEST bypass per-task (skip_permissions), but it is only
# HONORED when this is the literal string "true". Default-deny. Only arm this on
# an isolated execution node after Djimitflo's policy engine has pre-approved work.
# RUNTIME_ALLOW_SKIP_PERMISSIONS=false
#
# RUNTIME_ENV_PASSTHROUGH — comma-separated extra env var names to forward to
# spawned runtime children, beyond the built-in allowlist (PATH/HOME + model
# provider keys). The server's own secrets are never blanket-copied to children.
# RUNTIME_ENV_PASSTHROUGH=MY_RUNTIME_CONFIG_VAR
#
# LOOP_WORKTREE_ROOT — directory holding per-run git worktrees for runtime workers.
# Defaults to <repo-parent>/.djimitflo-loop-worktrees. Runtime cwds are boundary-
# checked against this (plus the system tmpdir for tests).
# LOOP_WORKTREE_ROOT=
#
# RUNTIME_MAX_CONCURRENCY — max live codex/opencode child processes across the
# server process. Additional leases queue at the runtime semaphore. Default: 4.
# RUNTIME_MAX_CONCURRENCY=4

# Nested spawn control (L1/L2) — a spawned runtime child calls back to the server
# over HTTP to spawn its own sub-agents (the real nested-spawn control loop).
# Defaults are default-deny: SPAWN_DEPTH_BUDGET=0 means roots cannot spawn children
# until an operator arms the tree. The control URL is auto-derived at startup from
# PORT/HOST (127.0.0.1 loopback) if unset; set it explicitly for Docker where the
# child may need the container's reachable address.
# DJIMITFLO_CONTROL_URL=http://127.0.0.1:3001/api/swarms/spawns
# SPAWN_DEPTH_BUDGET=0
# SPAWN_TREE_TOKEN_BUDGET=200000
# SPAWN_TREE_WALL_BUDGET_MS=600000
# SPAWN_TREE_MAX_CONCURRENT_CHILDREN=4
# Per-child grant ceilings (L2): a child gets min(remaining, ceiling). The
# cumulative tree budget is the hard bound; the ceiling stops one child grabbing
# the whole tree. Defaults tuned for real swarm sizes, not total/(depth+1).
# SPAWN_PER_DEPTH_TOKEN_CAP=50000
# SPAWN_PER_DEPTH_WALL_CAP_MS=120000
# HMAC secret for scoped spawn tokens. Reuses JWT_SECRET if unset. Set a strong
# dedicated secret in production (32+ chars).
# DJIMITFLO_SPAWN_TOKEN_SECRET=<set a 32+ char random string in production>

# Dashboard static files — path to built dashboard directory (for production serving)
# In development, the Vite dev server serves the dashboard separately.
# In Docker/production, this points to the built dashboard assets.
# DASHBOARD_PATH=/app/packages/dashboard/dist
#
# Workstation execution nodes should normally run API-only while the MacBook
# hosts the dashboard cockpit pointed at this API.
# DASHBOARD_SERVE_ENABLED=false

# Backup — directory for backup artifacts
# Defaults to <project-root>/.data/backups
# BACKUP_DIR=./.data/backups

# Hostname — used in backup manifest for identification
# Auto-detected in Docker environments via HOSTNAME env var
# HOSTNAME=my-server

# Dashboard (Vite dev overrides — set in packages/dashboard/.env.local)
# VITE_API_BASE=http://localhost:3001/api
# VITE_WS_URL=ws://localhost:3001/ws
