{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "djimit-agent-profile",
  "title": "Djimit Agent Profile",
  "type": "object",
  "required": ["id", "name", "division", "source_repo", "source_path", "version_hash", "persona", "mission", "rules", "activation_status"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "division": { "type": "string" },
    "description": { "type": "string" },
    "source_repo": { "type": "string" },
    "source_path": { "type": "string" },
    "version_hash": { "type": "string" },
    "persona": { "type": "string" },
    "mission": { "type": "string" },
    "rules": { "type": "array", "items": { "type": "string" } },
    "workflows": { "type": "array", "items": { "type": "string" } },
    "deliverables": { "type": "array", "items": { "type": "string" } },
    "success_metrics": { "type": "array", "items": { "type": "string" } },
    "memory_policy": { "type": "string" },
    "tools_required": { "type": "array", "items": { "type": "string" } },
    "runtime_targets": { "type": "array", "items": { "type": "string" } },
    "risk_profile": {
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "injection_score": { "type": "integer" },
        "overlap_score": { "type": "number" },
        "flags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evaluation_status": { "type": "string", "enum": ["pending", "passed", "rejected"] },
    "activation_status": { "type": "string", "enum": ["draft", "active", "rejected", "deactivated"] }
  },
  "additionalProperties": true
}
